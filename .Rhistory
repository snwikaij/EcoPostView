x            <- seq(3, 8, 0.01)
y_taxon      <- dnorm(x, 4.8, 0.2)
y_taxon      <- y_taxon/max(y_taxon)
y_assemblage <- dnorm(x, 5.5, 0.4)
y_assemblage <- y_assemblage/max(y_assemblage)
yc_taxon     <- cumsum(y_taxon)/sum(y_taxon)
yc_assemblage<- cumsum(y_assemblage)/sum(y_assemblage)
dfxy <- data.frame(t=rep(c("Taxon", "Assemblage"), each=length(x)),
x=c(x,x), y=c(y_taxon, y_assemblage), c=c(yc_taxon, yc_assemblage))
pl1 <- ggplot(dfxy, aes(exp(x), y, group=t, col=t))+
geom_line(lwd=1.2)+
scale_x_continuous(limits = c(0, 1000), expand = c(0, 0))+
theme_classic()+
ylab("Density")+labs(col=NULL)+
scale_color_manual(breaks=c("Taxon", "Assemblage"),
values=c("dodgerblue4", "tomato3"))+
theme(legend.position = "bottom",
axis.title.x = element_blank(),
axis.text = element_blank(),
axis.ticks = element_blank())
pl2 <- ggplot(dfxy, aes(exp(x), c, group=t, col=t))+
geom_line(lwd=1.2)+
scale_x_continuous(limits = c(0, 1000), expand = c(0, 0))+
theme_classic()+
ylab("Density")+
scale_color_manual(breaks=c("Taxon", "Assemblage"),
values=c("dodgerblue4", "tomato3"))+
theme(legend.position = "none",
axis.title.x = element_blank(),
axis.text = element_blank(),
axis.ticks = element_blank())
dfd <- data.frame(x, d=yc_assemblage-yc_taxon)
pl3 <- ggplot(dfd, aes(exp(x), d))+
geom_line(lwd=1.2)+
scale_x_continuous(limits = c(0, 1000), expand = c(0, 0))+
theme_classic()+
xlab("Environmental gradient")+
ylab("Distance in density")+
geom_segment(aes(x = 500, y = -.525,
xend = exp(x[which.max(abs(yc_assemblage-yc_taxon))])*1.2,
yend = -max(abs(yc_assemblage-yc_taxon))), lwd=1.2,
arrow = arrow(length = unit(0.25, "cm"), type = "closed"))+
geom_text(x=650, y=-0.5, label="Discriminatory point", fontface=2)+
geom_vline(xintercept = exp(x[which.max(abs(yc_assemblage-yc_taxon))]),
col="tomato3", lty=2, lwd=1.2)+
theme(legend.position = "none",
axis.text = element_blank(),
axis.ticks = element_blank())
