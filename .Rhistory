rownames(restitan) <- NULL
combined <- merge(test_results$summary[,c(1:4,9)], restitan[,c(1,9,11,13)], by="taxon")
newcomp                      <- combined$ul_location-combined$ll_location
titancomp                    <- combined$`95%`-combined$`5%`
combined$quantile_difference <- newcomp-titancomp
combined$split_difference    <- combined$location-combined$`50%`
fig2 <- ggplot(combined, aes(split_difference, quantile_difference, size=sqrt(n)))+
geom_vline(xintercept = 0, lty=3, lwd=0.8, col="tomato3")+
geom_hline(yintercept = 0, lty=3, lwd=0.8, col="tomato3")+
xlab("Discriminatory point difference")+ylab("Quantile range difference")+
geom_point(pch=19, alpha=0.2)+
scale_size_continuous(
name = "Number of observations",
breaks = c(4, 6, 8, 10),
labels = c(16, 36, 64, 100)
)+
labs(size="Number of observations")+
theme_classic()+
theme(legend.position = "bottom")
fig2
